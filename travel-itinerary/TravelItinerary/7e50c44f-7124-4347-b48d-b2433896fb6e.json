          },
          "endTime": {
            "value": "16:30"
          },
          "notes": "Liberty London is a must — beautiful Tudor-Revival building housing luxury and indie brands. Carnaby nearby is great for streetwear and lifestyle brands."
        },
        {
          "location": {
            "searchKey": "Covent Garden, London",
            "lat": 51.5117,
            "lon": -0.124
